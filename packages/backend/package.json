{
  "name": "keyway-api",
  "version": "0.1.0",
  "description": "GitHub-native secrets manager API",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "validate": "pnpm run lint && pnpm run type-check && pnpm run build",
    "deploy:check": "pnpm run type-check && pnpm run build",
    "prepare": "husky || true"
  },
  "keywords": [
    "secrets",
    "github",
    "api",
    "encryption"
  ],
  "author": "Nicolas Ritouet",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "@sentry/node": "10.45.0",
    "dotenv": "16.6.1",
    "drizzle-orm": "0.44.7",
    "fastify": "5.8.4",
    "jsonwebtoken": "9.0.3",
    "pino": "10.3.1",
    "postgres": "3.4.8",
    "posthog-node": "3.6.3",
    "resend": "6.9.4",
    "stripe": "20.4.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.19.37",
    "@vitest/coverage-v8": "4.1.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-security": "3.0.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
